generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// -----------------------------------------------------------------------------
// Identity
// -----------------------------------------------------------------------------

model Company {
  id                 String   @id @default(cuid())
  name               String   @unique
  industry           String?
  size               String?
  numberOfDepartments Int?
  logo               String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  users              User[]
  opportunities      InternalOpportunity[]
  departments        Department[]
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  name             String
  passwordHash     String
  role             String    @default("EMPLOYEE")
  companyId        String?
  departmentId     String?
  teamId           String?
  avatarUrl        String?
  deletedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  company          Company?    @relation(fields: [companyId], references: [id])
  department       Department? @relation(fields: [departmentId], references: [id])
  team             Team?       @relation(fields: [teamId], references: [id])
  
  // Relations
  employeeSkills       EmployeeSkill[]
  skillGaps            SkillGap[]
  promotionAssessments PromotionAssessment[] @relation("UserAssessed")
  assessmentsGiven     PromotionAssessment[] @relation("ManagerAssessor")
  learningEnrollments  LearningEnrollment[]
  mentorshipsAsMentor  MentorshipEnrollment[] @relation("Mentor")
  mentorshipsAsMentee  MentorshipEnrollment[] @relation("Mentee")
  postedOpportunities  InternalOpportunity[]
  applications         OpportunityApplication[]
  successionProfile    SuccessionCandidate?
  profile              Profile?
  auditLogs            AuditLog[]
  notifications        Notification[]
}

model Role {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  permissions Permission[]
}

model Permission {
  id        String   @id @default(cuid())
  roleId    String
  resource  String
  action    String
  createdAt DateTime @default(now())
  role      Role     @relation(fields: [roleId], references: [id])
}

// -----------------------------------------------------------------------------
// Organization
// -----------------------------------------------------------------------------

model Department {
  id          String       @id @default(cuid())
  companyId   String
  name        String
  description String?
  parentId    String?
  parent      Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children    Department[] @relation("DepartmentHierarchy")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  company            Company               @relation(fields: [companyId], references: [id])
  users              User[]
  teams              Team[]
  careerPaths        CareerPath[]
  internalOpportunities InternalOpportunity[]
}

model Team {
  id           String      @id @default(cuid())
  name         String
  departmentId String
  managerId    String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  department   Department  @relation(fields: [departmentId], references: [id])
  users        User[]
  internalOpportunities InternalOpportunity[]
}

// -----------------------------------------------------------------------------
// Skills
// -----------------------------------------------------------------------------

model SkillCategory {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  skills      Skill[]
}

model Skill {
  id          String        @id @default(cuid())
  name        String        @unique
  description String?
  categoryId  String
  deletedAt   DateTime?
  createdBy   String?
  updatedBy   String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  category         SkillCategory     @relation(fields: [categoryId], references: [id])
  employeeSkills   EmployeeSkill[]
  skillGaps        SkillGap[]
  careerRoleSkills CareerRoleSkill[]
}

model EmployeeSkill {
  userId      String
  skillId     String
  level       Int       // 1-5
  evidence    String?
  assessedAt  DateTime  @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id])
  skill       Skill     @relation(fields: [skillId], references: [id])

  @@id([userId, skillId])
}

model SkillGap {
  id           String      @id @default(cuid())
  userId       String
  skillId      String
  currentLevel Int
  requiredLevel Int
  gapSize      Int
  careerRoleId String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  user         User        @relation(fields: [userId], references: [id])
  skill        Skill       @relation(fields: [skillId], references: [id])
  careerRole   CareerRole? @relation(fields: [careerRoleId], references: [id])
}

// -----------------------------------------------------------------------------
// Career
// -----------------------------------------------------------------------------

model CareerPath {
  id           String       @id @default(cuid())
  name         String
  description  String?
  departmentId String?
  deletedAt    DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  department   Department?  @relation(fields: [departmentId], references: [id])
  roles        CareerRole[]
}

model CareerRole {
  id                String            @id @default(cuid())
  careerPathId      String
  title             String
  level             Int               // Order in path
  experienceYears   Int?
  leadershipRequired Boolean          @default(false)
  deletedAt         DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  careerPath        CareerPath        @relation(fields: [careerPathId], references: [id])
  requiredSkills    CareerRoleSkill[]
  skillGaps         SkillGap[]
  assessments       PromotionAssessment[]
}

model CareerRoleSkill {
  careerRoleId  String
  skillId       String
  requiredLevel Int     // 1-5

  careerRole    CareerRole @relation(fields: [careerRoleId], references: [id])
  skill         Skill      @relation(fields: [skillId], references: [id])

  @@id([careerRoleId, skillId])
}

model PromotionAssessment {
  id               String           @id @default(cuid())
  userId           String
  targetRoleId     String
  status           String           // READY, NEAR_READY, DEVELOPMENT_NEEDED
  skillScore       Float
  learningScore    Float
  managerScore     Float
  leadershipScore  Float
  overallScore     Float
  notes            String?
  assessedById     String
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  user             User             @relation("UserAssessed", fields: [userId], references: [id])
  assessor         User             @relation("ManagerAssessor", fields: [assessedById], references: [id])
  targetRole       CareerRole       @relation(fields: [targetRoleId], references: [id])
}

// -----------------------------------------------------------------------------
// Learning
// -----------------------------------------------------------------------------

model LearningResource {
  id          String    @id @default(cuid())
  providerId  String    @unique // External ID (e.g. from Udemy)
  provider    String    // e.g. "UDEMY"
  title       String
  description String?
  url         String
  imageUrl    String?
  instructor  String?
  duration    Int?      // Minutes
  category    String?
  level       String?
  skills      String?   // JSON string of skills taught
  active      Boolean   @default(true)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  enrollments LearningEnrollment[]
}

model LearningPlan {
  id          String    @id @default(cuid())
  providerId  String?   // External learning path ID if applicable
  provider    String?
  title       String
  description String?
  courseIds   String    // JSON string
  createdBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  enrollments LearningEnrollment[]
}

model LearningEnrollment {
  id                 String           @id @default(cuid())
  userId             String
  learningResourceId String?
  learningPlanId     String?
  status             String           // NOT_STARTED, IN_PROGRESS, COMPLETED
  progressPercent    Int              @default(0)
  enrolledAt         DateTime         @default(now())
  completedAt        DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  user               User              @relation(fields: [userId], references: [id])
  resource           LearningResource? @relation(fields: [learningResourceId], references: [id])
  plan               LearningPlan?     @relation(fields: [learningPlanId], references: [id])
}

// -----------------------------------------------------------------------------
// Mentorship
// -----------------------------------------------------------------------------

model MentorshipProgram {
  id          String            @id @default(cuid())
  name        String
  description String?
  status      String            @default("ACTIVE") // ACTIVE, PAUSED, COMPLETED
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  enrollments MentorshipEnrollment[]
}

model MentorshipEnrollment {
  id          String    @id @default(cuid())
  programId   String
  mentorId    String
  menteeId    String
  status      String    // PENDING, ACTIVE, COMPLETED
  startDate   DateTime
  endDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  program     MentorshipProgram @relation(fields: [programId], references: [id])
  mentor      User              @relation("Mentor", fields: [mentorId], references: [id])
  mentee      User              @relation("Mentee", fields: [menteeId], references: [id])
}

// -----------------------------------------------------------------------------
// Opportunities
// -----------------------------------------------------------------------------

model InternalOpportunity {
  id            String    @id @default(cuid())
  companyId     String
  title         String
  description   String
  departmentId  String?
  teamId        String?
  requiredSkills String    // JSON string
  status        String    @default("OPEN") // OPEN, CLOSED
  deletedAt     DateTime?
  postedById    String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  company       Company     @relation(fields: [companyId], references: [id])
  postedBy      User        @relation(fields: [postedById], references: [id])
  department    Department? @relation(fields: [departmentId], references: [id])
  team          Team?       @relation(fields: [teamId], references: [id])
  applications  OpportunityApplication[]
}

model OpportunityApplication {
  id            String    @id @default(cuid())
  opportunityId String
  userId        String
  status        String    @default("APPLIED") // APPLIED, SHORTLISTED, ACCEPTED, REJECTED
  appliedAt     DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  opportunity   InternalOpportunity @relation(fields: [opportunityId], references: [id])
  user          User                @relation(fields: [userId], references: [id])
}

// -----------------------------------------------------------------------------
// Succession
// -----------------------------------------------------------------------------

model SuccessionCandidate {
  id            String    @id @default(cuid())
  userId        String    @unique
  targetRoleId  String
  readiness     String    // READY, NEAR_READY, DEVELOPMENT_NEEDED
  identifiedById String
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user          User      @relation(fields: [userId], references: [id])
}

// -----------------------------------------------------------------------------
// Profile
// -----------------------------------------------------------------------------

model Profile {
  id                  String   @id @default(cuid())
  userId              String   @unique
  jobTitle            String
  yearsOfExperience   Int
  careerGoal          String
  bio                 String?
  linkedInUrl         String?
  targetRoleId        String?
  managerLevel        String?
  hrFunction          String?
  businessUnit        String?
  leadershipLevel     String?
  administrationScope String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user                User     @relation(fields: [userId], references: [id])
}

// -----------------------------------------------------------------------------
// Invitations
// -----------------------------------------------------------------------------

model Invitation {
  id           String    @id @default(cuid())
  token        String    @unique
  email        String
  firstName    String
  lastName     String
  role         String    // EMPLOYEE, MANAGER, HR, LEADERSHIP, ADMINISTRATOR
  departmentId String?
  teamId       String?
  jobTitle     String?
  managerId    String?
  expiresAt    DateTime
  status       String    @default("PENDING") // PENDING, ACCEPTED, EXPIRED, REVOKED
  createdBy    String
  acceptedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// -----------------------------------------------------------------------------
// Password Reset
// -----------------------------------------------------------------------------

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
}

// -----------------------------------------------------------------------------
// Platform
// -----------------------------------------------------------------------------

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   // INFO, WARNING, SUCCESS, ERROR
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String   // CREATE, UPDATE, DELETE
  entity    String
  entityId  String
  previous  String?  // JSON string
  new       String?  // JSON string
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
}
